{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Meridian",
  "version": "0.8.5",
  "identifier": "io.github.azam997.meridian",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meridian",
        "width": 1600,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/fflogs-efficiency-analyzer-sidecar"],
    "resources": {
      "binaries/_internal/": "_internal/"
    },
    "createUpdaterArtifacts": true,
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGNTQ2OUM2QTE2NDRFOTcKUldTWFRtU2h4bWxVWHlMY2tiSE5hcDhsV3JiNHRNN3QzbnJTZG9EWnU3aDE1ZUNTTmZnSHI1OTgK",
      "endpoints": [
        "https://github.com/azam997/meridian-releases/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
